<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:padding="16dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#FFFFFF"
            android:layout_centerVertical="true"
            android:contentDescription="Quay lại" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="TÍNH ĐIỂM CẦN THI"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Chọn môn học -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Chọn môn học"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:textStyle="bold"/>
                <Button
                    android:id="@+id/btnSyncDiemTP"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="Lấy điểm từ Web"
                    android:textSize="11sp"
                    android:backgroundTint="#FF9800"
                    android:textColor="#FFFFFF"
                    android:paddingHorizontal="8dp"/>
            </LinearLayout>

            <Spinner
                android:id="@+id/spnMonHoc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/btn_dropdown"
                android:theme="@style/ThemeOverlay.AppCompat.Light" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn hệ số trọng số (TX1-TX2-TX3-Thi)"
                android:textSize="14sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <Spinner
                android:id="@+id/spnTrongSo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:theme="@style/ThemeOverlay.AppCompat.Light"
                android:layout_marginBottom="16dp"/>

            <!-- Điểm thành phần -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điểm thường xuyên 1"
                android:textSize="14sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/edtTx1"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nhập điểm TX1"
                android:inputType="numberDecimal"
                android:background="@android:drawable/editbox_background"
                android:paddingStart="12dp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Điểm thường xuyên 2"
                android:textSize="14sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <EditText
                android:id="@+id/edtTx2"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Nhập điểm TX2"
                android:inputType="numberDecimal"
                android:background="@android:drawable/editbox_background"
                android:paddingStart="12dp"
                android:textColor="#000000"
                android:layout_marginBottom="16dp"/>

            <!-- Điểm TX3 (Có thể bị ẩn) -->
            <LinearLayout
                android:id="@+id/layoutTx3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Điểm thường xuyên 3"
                    android:textSize="14sp"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edtTx3"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Nhập điểm TX3"
                    android:inputType="numberDecimal"
                    android:background="@android:drawable/editbox_background"
                    android:paddingStart="12dp"
                    android:textColor="#000000"
                    android:layout_marginBottom="16dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mục tiêu điểm chữ"
                android:textSize="14sp"
                android:textColor="#212121"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>
            <Spinner
                android:id="@+id/spnMucTieu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="48dp"
                android:background="@android:drawable/btn_dropdown"
                android:theme="@style/ThemeOverlay.AppCompat.Light"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnTinhToan"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="TÍNH TOÁN"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:id="@+id/layoutKetQua"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#E8F5E9"
                android:padding="16dp"
                android:layout_marginTop="24dp"
                android:visibility="gone">
                <TextView
                    android:id="@+id/tvKetQua"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="---"
                    android:textSize="18sp"
                    android:textColor="#2E7D32"
                    android:textStyle="bold"
                    android:gravity="center"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>